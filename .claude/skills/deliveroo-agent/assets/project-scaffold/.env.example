# Copy to `.env` and fill in.
# Generate a token via the 3D client by entering a name.
# Tokens are per-server — a local token won't work on cloud, and vice versa.

# --- Local server ---
HOST=localhost:8080
TOKEN=

# --- Cloud (free tier, slow under load) ---
# HOST=deliveroojs.onrender.com
# TOKEN=

# --- UniTN internal (needs VPN) ---
# HOST=deliveroojs.bears.disi.unitn.it
# TOKEN=

# --- Second agent (for multi-agent coordination) ---
TOKEN_SECOND=

# --- LLM agent (Phase 2) ---
LLM_API_URL=
LLM_API_TOKEN=
TOOLS_CATALOG_URL=
